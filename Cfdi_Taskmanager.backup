INSERT INTO public.organizations (id, name, slug, logo, description, created_at, updated_at, "ownerId", "onboardingCompleted", "setupRequirements", "operationalAccessEnabled", address, city, state, postal_code, country, phone, contact_email, business_description, website, industry, company_size, founded_year, tax_id, business_type, system_settings) VALUES ('cmjdco6rw0002vyc8d1v66w3k', 'Corporativo Devlin', 'ppnajera', '/uploads/logos/5ea0847d-3480-47b9-83e1-762d828e6064.jpeg', 'Grupo Devlyn es la cadena de ópticas líder y más grande de México, una empresa familiar 100% mexicana con más de 85 años de experiencia, enfocada en cuidado visual integral (lentes, armazones, etc.) con alta tecnología y calidez, y una fuerte misión social a través de su Fundación Devlyn, que ofrece exámenes y lentes gratuitos, buscando que la visión sea un derecho, no un privilegio, beneficiando a millones de mexicanos. ', '2025-12-19 20:56:58.7', '2025-12-19 22:34:44.514', 'cmjdco6rr0000vyc82otkwsuo', true, '{"minUsers": 2, "minCompanies": 1, "requiredSteps": ["COMPANY_REGISTRATION", "USER_INVITATION", "PROFILE_ASSIGNMENT"]}', false, 'Blvd. Miguel de Cervantes Saavedra No. 31, Colonia Granada', 'Delegación Miguel Hidalgo', 'CDMX', '11520', 'México', '2223819613', 'pnajera@itcomplements.com', 'Puntos Clave:
Líder en Óptica: Es la cadena óptica más grande de México y América Latina, con presencia en centros comerciales clave.
Empresa Familiar: Fundada hace más de 80 años en Ciudad Juárez, Chihuahua, y actualmente dirigida por la tercera generación.
Servicio Integral: Ofrece exámenes de la vista, una amplia gama de armazones, tratamientos, lentes de contacto y aparatos auditivos.
Innovación y Calidad: Combina experiencia con tecnología, como su laboratorio y centro de distribución, e incorpora IA para mejorar procesos.
Responsabilidad Social (Fundación Devlyn): A través de su fundación, proporciona servicios visuales gratuitos a comunidades vulnerables, impactando positivamente en el aprendizaje y productividad.
Misión: "Que la visión sea un derecho y no un privilegio", haciendo que las personas se vean y se sientan bien. ', 'https://www.devlyn.com.mx/', 'Comercio', '501-1000 empleados', 1980, '', 'Sociedad Anónima', '{}');
INSERT INTO public.organizations (id, name, slug, logo, description, created_at, updated_at, "ownerId", "onboardingCompleted", "setupRequirements", "operationalAccessEnabled", address, city, state, postal_code, country, phone, contact_email, business_description, website, industry, company_size, founded_year, tax_id, business_type, system_settings) VALUES ('cmlsoj45j0002fdr8k3e3cydd', 'Org Demo', 'org-demo-1771458294723', NULL, NULL, '2026-02-18 23:44:54.727', '2026-02-18 23:44:54.727', 'cmlsoj44t0000fdr8h33xljg3', true, '{"minUsers": 2, "minCompanies": 1}', true, NULL, NULL, NULL, NULL, 'México', NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, '{}');
INSERT INTO public.organizations (id, name, slug, logo, description, created_at, updated_at, "ownerId", "onboardingCompleted", "setupRequirements", "operationalAccessEnabled", address, city, state, postal_code, country, phone, contact_email, business_description, website, industry, company_size, founded_year, tax_id, business_type, system_settings) VALUES ('cmipiwlqk000mvyvtc22tnlrb', 'ITComplements', 'pnajera', '/uploads/logos/12b940f4-022b-491a-bdb8-5d027f7fef56.png', 'Somos el grupo mexicano con tecnología propia #1 en el desarrollo de soluciones informáticas para el mercado corporativo y gubernamental en México', '2025-12-03 04:45:00.812', '2026-02-05 15:33:31.949', 'cmipiwlqh000kvyvtvip09kot', true, '{"minUsers": 2, "minCompanies": 1, "requiredSteps": ["COMPANY_REGISTRATION", "USER_INVITATION", "PROFILE_ASSIGNMENT"]}', false, 'Privada 4 A Poniente 331', 'Ciudad de México', 'Puebla', '11000', 'México', '2223819613', 'pnajera@itcomplements.com', 'Empresa Nacional Desarrolladora de Soluciones Especializadas en TI (Tecnología de la Información).  Proveemos, desde hace más de 20 años, soluciones en forma de herramientas de software acompañados de servicios de consultoría y transferencia tecnológica.

Creemos en el futuro de México y en nuestro poder de innovación, desarrollando soluciones de TI “Nacionales” para generar riqueza y distribuirla en México.', 'https://www.itcomplements.com/', 'Tecnología', '11-50 empleados', 1990, NULL, 'Sociedad Anónima', '{"theme": "light", "preferences": {}}');


